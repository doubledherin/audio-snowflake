{
  "name": "audio-snowflake-client",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@apollo/react-hooks": "^3.1.5",
    "@reach/router": "^1.3.3",
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^9.5.0",
    "@testing-library/user-event": "^7.2.1",
    "apollo-cache-inmemory": "^1.6.5",
    "apollo-client": "^2.6.8",
    "graphql": "^15.0.0",
    "graphql-tag": "^2.10.3",
    "node-sass": "^4.13.1",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-scripts": "3.4.1"
  },
  "scripts": {
    "start": "npm-run-all -p start-server build-fragment",
    "start-server": "react-scripts start",
    "build-fragment": "node src/schemaQuery.js",
    "build": "react-scripts build",
    "test": "jest --verbose",
    "test:watch": "npm run test -- --watch --verbose",
    "test:coverage": "npm run test -- --coverage",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/preset-env": "^7.9.5",
    "apollo": "^2.27.0",
    "npm-run-all": "^4.1.5",
    "react-apollo": "^3.1.5"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "__fixtures"
    ],
    "coverageReporters": [
      "html"
    ]
  }
}
